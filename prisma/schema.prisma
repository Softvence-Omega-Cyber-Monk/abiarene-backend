generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  EXPIRED
}

enum SubscriptionPaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum SubscriptionPaymentProvider {
  STRIPE
  ORANGE
  MTN_MOMO
  PAYSTACK
  GODADDY_PAYMENTS
}

enum RoleName {
  MANAGER
  SUPERVISOR
  SERVER
  KITCHEN
  CASHIER
  ADMIN
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
}

enum OrderStatus {
  CONFIRMED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum OrderType {
  DINE_IN
  DIRECT
}

enum TicketStatus {
  ACTIVE
  READY
  ARCHIVED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  MANUAL
}

enum SupportTicketStatus {
  OPEN
  CLOSED
}

enum SupportMessageSenderRole {
  ADMIN
  SUPERVISOR
}

enum NotificationType {
  ORDER_SENT_TO_KITCHEN
  ORDER_CANCELLED
  ORDER_READY
  ORDER_ARCHIVED
  PAYMENT_COMPLETED
  SUBSCRIPTION_PAID
  GENERIC
}

enum InventoryDeletionRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubscriptionPlanType {
  FREE
  MONTHLY
  YEARLY
}

enum IndustryType {
  RESTAURANT
  BAR
  SUPERMARKET
  HARDWARE_STORE
  WINE_SHOP
  CLOTHING_AND_FASHION_SHOP
  BOOKSHOP
  COSMETIC_AND_SKINCARE_SHOP
  CONSTRUCTION_SHOP
  OTHER
}

// ─── Tenant ─────────────────────────────────────────────────────

model Tenant {
  id              String       @id @default(uuid())
  name            String
  industry        IndustryType @default(OTHER)
  mobileLogo      String?
  tabletLogo      String?
  subscriptionFee Float        @default(0)
  startsWithFreeTrial Boolean  @default(false)
  status          TenantStatus @default(ACTIVE)
  subscriptionStatus SubscriptionStatus @default(PENDING)
  subscriptionStartAt DateTime?
  subscriptionEndAt DateTime?
  lastSync        DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  users           User[]
  roles           Role[]
  products        Product[]
  menu            Menu?
  menuItems       MenuItem[]
  tables          Table[]
  orders          Order[]
  tickets         Ticket[]
  payments        Payment[]
  subscriptionPayments SubscriptionPayment[]
  subscriptionVouchers SubscriptionVoucher[]
  discounts       Discount[]
  supportTickets  SupportTicket[]
  notifications   Notification[]
  inventoryDeletionRequests InventoryDeletionRequest[]

  @@map("tenants")
}

model Menu {
  id         String          @id @default(uuid())
  tenantId    String         @unique
  name       String
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items      MenuSelection[]

  @@map("menus")
}

// ─── Role ───────────────────────────────────────────────────────

model Role {
  id        String   @id @default(uuid())
  name      RoleName
  tenantId  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users     User[]

  @@index([tenantId])
  @@unique([name, tenantId])
  @@map("roles")
}

// ─── User ───────────────────────────────────────────────────────

model User {
  id        String     @id @default(uuid())
  name      String
  image     String?
  email     String
  pin       String?
  tokenVersion Int     @default(0)
  pendingRole RoleName?
  roleId    String?
  tenantId  String?
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  role      Role?      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  tenant    Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders    Order[]    @relation("CreatedByUser")
  subscriptionPayments SubscriptionPayment[]
  notifications Notification[]
  requestedInventoryDeletionRequests InventoryDeletionRequest[] @relation("RequestedInventoryDeletionRequests")
  approvedInventoryDeletionRequests InventoryDeletionRequest[] @relation("ApprovedInventoryDeletionRequests")
  usedSubscriptionVouchers SubscriptionVoucher[] @relation("UsedSubscriptionVouchers")

  @@unique([email])
  @@index([tenantId])
  @@map("users")
}

// ─── Admin ──────────────────────────────────────────────────────

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  pin       String
  name      String
  image     String?
  tokenVersion Int    @default(0)
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  notifications Notification[]
  subscriptionPrices SubscriptionPrice[]
  createdSubscriptionVouchers SubscriptionVoucher[]

  @@map("admins")
}

model SubscriptionPrice {
  id          String   @id @default(uuid())
  name        String
  planType    SubscriptionPlanType @default(MONTHLY)
  description String?
  amount      Float
  currency    String   @default("USD")
  isActive    Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy   Admin    @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@unique([planType])
  @@index([isActive])
  @@index([createdById])
  @@map("subscription_prices")
}

// ─── Product ────────────────────────────────────────────────────

model Product {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  sku       String?
  barcode   String?
  price     Float
  stock     Int      @default(0)
  lowStockThreshold Int @default(10)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stockLogs StockLog[]
  orderItems OrderItem[]

  @@index([tenantId])
  @@unique([sku, tenantId])
  @@map("products")
}

model InventoryDeletionRequest {
  id          String   @id @default(uuid())
  tenantId    String
  productId   String
  productName String
  productSku  String?
  requestedByUserId String
  approvedByUserId String?
  status      InventoryDeletionRequestStatus @default(PENDING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requestedBy User     @relation("RequestedInventoryDeletionRequests", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  approvedBy  User?    @relation("ApprovedInventoryDeletionRequests", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, createdAt])
  @@unique([tenantId, productId, status])
  @@map("inventory_deletion_requests")
}

// ─── Stock Log ──────────────────────────────────────────────────

model StockLog {
  id        String   @id @default(uuid())
  productId String
  change    Int
  reason    String
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("stock_logs")
}

// ─── Tenant Item ────────────────────────────────────────────────

model MenuItem {
  id          String          @id @default(uuid())
  tenantId    String
  image       String?
  name        String
  category    String
  description String?
  options     String[]        @default([])
  price       Float
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  menuSelections MenuSelection[]
  orderItems  OrderItem[]

  @@index([tenantId])
  @@map("menu_items")
}

// ─── Table ──────────────────────────────────────────────────────

model Table {
  id          String      @id @default(uuid())
  tenantId    String
  tableNumber Int
  seatCount   Int         @default(4)
  status      TableStatus @default(AVAILABLE)
  served      Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders      Order[]

  @@index([tenantId])
  @@unique([tableNumber, tenantId])
  @@map("tables")
}

model MenuSelection {
  id         String    @id @default(uuid())
  menuId      String
  itemId      String
  createdAt   DateTime @default(now())

  menu        Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)
  item        MenuItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([menuId])
  @@index([itemId])
  @@unique([menuId, itemId])
  @@map("menu_selections")
}

// ─── Order ──────────────────────────────────────────────────────

model Order {
  id         String      @id @default(uuid())
  tenantId   String
  tableId    String?
  orderType  OrderType   @default(DINE_IN)
  status     OrderStatus @default(CONFIRMED)
  createdBy  String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  table      Table?      @relation(fields: [tableId], references: [id], onDelete: Cascade)
  user       User        @relation("CreatedByUser", fields: [createdBy], references: [id], onDelete: Cascade)
  items      OrderItem[]
  tickets    Ticket[]
  payments   Payment[]

  @@index([tenantId])
  @@index([tableId])
  @@index([createdBy])
  @@map("orders")
}

// ─── Order Item ─────────────────────────────────────────────────

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  menuItemId String?
  productId  String?
  itemName   String?
  itemCategory String?
  itemImage  String?
  unitPrice  Float?
  quantity   Int      @default(1)
  notes      String?
  selectedOptions String[] @default([])
  createdAt  DateTime @default(now())

  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem   MenuItem?  @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  product    Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)
  ticketItems TicketItem[]

  @@index([orderId])
  @@index([menuItemId])
  @@index([productId])
  @@map("order_items")
}

// ─── Ticket ─────────────────────────────────────────────────────

model Ticket {
  id        String       @id @default(uuid())
  ticketCode String      @unique
  orderId   String
  tenantId  String
  status    TicketStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  order     Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items     TicketItem[]

  @@index([tenantId])
  @@index([orderId])
  @@map("tickets")
}

// ─── Ticket Item ────────────────────────────────────────────────

model TicketItem {
  id          String    @id @default(uuid())
  ticketId    String
  orderItemId String

  ticket      Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_items")
}

// ─── Payment ────────────────────────────────────────────────────

model Payment {
  id        String        @id @default(uuid())
  orderId   String
  tenantId  String
  amount    Float
  status    PaymentStatus @default(PENDING)
  method    PaymentMethod @default(CASH)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([orderId])
  @@map("payments")
}

model SubscriptionPayment {
  id               String                      @id @default(uuid())
  tenantId         String
  userId           String
  voucherId        String?
  provider         SubscriptionPaymentProvider
  originalAmount   Float?
  discountAmount   Float                       @default(0)
  amount           Float
  currency         String                      @default("USD")
  status           SubscriptionPaymentStatus   @default(PENDING)
  reference        String                      @unique
  externalReference String?
  completedAt      DateTime?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  tenant           Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  voucher          SubscriptionVoucher?        @relation("SubscriptionPaymentVoucher", fields: [voucherId], references: [id], onDelete: SetNull)
  consumedVoucher  SubscriptionVoucher?        @relation("SubscriptionVoucherUsedPayment")

  @@index([tenantId])
  @@index([userId])
  @@index([voucherId])
  @@map("subscription_payments")
}

model SubscriptionVoucher {
  id                 String               @id @default(uuid())
  tenantId           String
  code               String
  amountOff          Float
  isActive           Boolean              @default(true)
  expiresAt          DateTime?
  reservedByPaymentId String?
  usedAt             DateTime?
  usedByUserId       String?
  usedInPaymentId    String?              @unique
  createdById        String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy          Admin                @relation(fields: [createdById], references: [id], onDelete: Cascade)
  usedBy             User?                @relation("UsedSubscriptionVouchers", fields: [usedByUserId], references: [id], onDelete: SetNull)
  usedInPayment      SubscriptionPayment? @relation("SubscriptionVoucherUsedPayment", fields: [usedInPaymentId], references: [id], onDelete: SetNull)
  payments           SubscriptionPayment[] @relation("SubscriptionPaymentVoucher")

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@index([createdById])
  @@index([usedByUserId])
  @@map("subscription_vouchers")
}

// ─── Discount ───────────────────────────────────────────────────

model Discount {
  id           String   @id @default(uuid())
  tenantId      String
  name         String
  minimumPrice Float
  offPrice     Float
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("discounts")
}

model Notification {
  id        String           @id @default(uuid())
  tenantId  String?
  userId    String?
  adminId   String?
  type      NotificationType
  title     String
  message   String
  payload   Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  tenant    Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  admin     Admin?           @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([adminId])
  @@index([isRead])
  @@map("notifications")
}

// ─── Support Ticket ─────────────────────────────────────────────

model SupportTicket {
  id        String              @id @default(uuid())
  tenantId  String
  subject   String
  message   String
  status    SupportTicketStatus @default(OPEN)
  response  String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages  SupportTicketMessage[]

  @@index([tenantId])
  @@map("support_tickets")
}

model SupportTicketMessage {
  id         String                   @id @default(uuid())
  ticketId    String
  senderRole  SupportMessageSenderRole
  senderName  String
  senderEmail String
  message     String
  createdAt   DateTime                @default(now())

  ticket      SupportTicket           @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("support_ticket_messages")
}
